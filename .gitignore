# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local caches
.turbo/
.eslintcache

# misc
.DS_Store
Thumbs.db
*.pem
*.key
*.p12
*.p8
*.crt
*.cer
*.secret
secrets.*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server*.log
.codex-*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase local state
supabase/.branches
supabase/.temp
.supabase/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
